# ===================================================================
# REPORT-AI — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
# ===================================================================

# --- Genel ---
PROJECT_NAME=REPORT-AI
VERSION=0.1.0
DEBUG=true

# --- API ---
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:4200"]

# --- Veritabanı (İleride aktif edilecek) ---
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/report_ai

# --- AI Model ---
MODEL_WEIGHTS_PATH=ai/weights/best.pt
MODEL_CONFIDENCE_THRESHOLD=0.5

# --- Loglama ---
LOG_LEVEL=INFO
